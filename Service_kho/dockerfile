# Build stage
FROM node:20-alpine AS builder

WORKDIR /build

# Cache dependencies
COPY package*.json ./
RUN npm install

# Copy source và build (nếu có dùng TypeScript/Babel, nếu JS thuần thì bỏ qua bước build)
COPY . .
# RUN npm run build 

# Runtime stage
FROM node:20-alpine

WORKDIR /app

# Bảo mật: Chạy với user node (có sẵn trong image alpine)
USER node

# Copy từ builder
COPY --from=builder /build/package*.json ./
COPY --from=builder /build/node_modules ./node_modules
COPY --from=builder /build ./ 

EXPOSE 3000

CMD ["node", "index.js"] 
